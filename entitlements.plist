<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Entitlements pour NetHealth.app sous hardened runtime.

        Les 2 premières sont nécessaires parce que le runtime Python génère
        du code à la volée (compile du bytecode en mémoire) et que PyObjC
        dlopen dynamiquement les frameworks CoreWLAN/Cocoa. Sans ces flags,
        l'app se fait tuer au lancement sous hardened runtime.
    -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Accès réseau sortant (ping, speedtest, interroger le TP-Link…) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Accès réseau entrant (inutile ici, mais inoffensif) -->
    <key>com.apple.security.network.server</key>
    <false/>
</dict>
</plist>
